# Copy to .env.local and fill in real values. Never commit .env.local.
# See README.md §6 "Environment variables" for what each key is for.

NEXT_PUBLIC_SUPABASE_URL=
# Project's publishable key (sb_publishable_...) or legacy anon key from
# Settings > API Keys. Fixed spelling — do not alias as ..._PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server/worker only — bypasses RLS, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Pooled connection string for the worker tier.
DATABASE_URL=

RESEND_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
