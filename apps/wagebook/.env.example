# Supabase project URL and publishable key — safe to expose to the browser
# (NEXT_PUBLIC_ prefix). Get both from the Project Settings > API Keys page.
# Never put the secret/service_role key in a NEXT_PUBLIC_ variable.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key — server-only, NEVER prefix with NEXT_PUBLIC_ and never
# import it from a Client Component. Used exclusively by
# src/lib/supabase/admin.ts to send employee self-service account invites
# (auth.admin.inviteUserByEmail). Get it from Project Settings > API Keys.
SUPABASE_SERVICE_ROLE_KEY=
